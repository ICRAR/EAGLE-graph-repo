                "779239a9-fbf4-4624-870c-d91f180c0efd": {
                    "name": "comment",
                    "value": "Start with these:\n \ncreate_blockvisibility_from_ms (whcih should take the ms file name from Config)\ncreate_low_test_skycomponents_from_gleam\ndft_skycomponent_visibility\nsolve_gaintable\n\n \nthen\ngrid_blockvisibility_to_griddata\nfft_griddata_to_image\nfind_skycomponents",
