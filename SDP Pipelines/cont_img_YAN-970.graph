        "68408a04-31fc-4f6c-87a9-ecb4275b4ef7": {
            "category": "Loop",
            "categoryType": "Construct",
            "id": "68408a04-31fc-4f6c-87a9-ecb4275b4ef7",
            "name": "Major Cycle",
            "description": "The major cycle is starting from visibilities and weights, produces a dirty image and a PSF image and enters the minor cycle. If new components are still available after all the minor cycles have been executed, these components will be used to produce modelled visibilities, subtract those from the original visibilities, flag them, if necessary and then generate an updated dirty image and an updated PSF image to start the cycle again. The major cycle is finished if no more components are found, or once all configured cycles have been executed.",
            "x": 1240.7261681137575,
            "y": 788.6537628444374,
            "repositoryUrl": "",
            "commitHash": "",
