                "c1f81798-3a63-4174-9f59-6535facd0936": {
                    "name": "comment",
                    "value": "Starts with DFT skycomponents to produce modelvis\nInput from GLEMA model as sc_ref\n\nSolve gain table\n   Self-cal converged?\n   Y - save and quit\n   N - continue\nApply GT to VIS\nSubtract model from VIS\nFlag to generate VIS\n\nRecive major loop components in the \nFIND SKYCOM MATCHs to merge with REFEENCE SC \nOuput SC as END\nReturn to DFT\n",
                    "defaultValue": "",
                    "description": "The text value of the comment",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "c1f81798-3a63-4174-9f59-6535facd0936",
                    "parameterType": "Component",
                    "usage": "NoPort",
                    "edgeIds": []
                }
            },
