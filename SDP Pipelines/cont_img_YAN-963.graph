        "f0ac96e1-deb8-406a-9e4c-c3b443de211d": {
            "category": "PythonApp",
            "categoryType": "Application",
            "id": "f0ac96e1-deb8-406a-9e4c-c3b443de211d",
            "name": "apply_gaintable",
            "description": "Apply a gain table to a block visibility\n\nThe corrected visibility is::\n\n    V_corrected = {g_i * g_j^*}^-1 V_obs\n\nIf the visibility data are polarised e.g. polarisation_frame(\"linear\") then the inverse operator\nrepresents an actual inverse of the gains.",
            "x": 1986.7871582032863,
            "y": 133.63941097245305,
            "repositoryUrl": "",
            "commitHash": "",
            "paletteDownloadUrl": "",
            "dataHash": "",
            "parentId": "401c3787-bce7-46cb-91eb-760ec8b45f22",
            "embedId": null,
            "fields": {
                "a4d524b3-86a1-4c7b-9992-8752ed786e97": {
                    "name": "persist",
