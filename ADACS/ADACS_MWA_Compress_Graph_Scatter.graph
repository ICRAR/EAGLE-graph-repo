        "5297cdd5-4c28-4417-b459-7bb3f82a7fb3": {
            "category": "PyFuncApp",
            "categoryType": "Application",
            "id": "5297cdd5-4c28-4417-b459-7bb3f82a7fb3",
            "name": "PyFunc-ExtractObsID",
            "description": "An application that wraps a python function. The inputs of the application are treated as the arguments of the function. Conversely, the output of the function is treated as the output of the application. If the application has more than one output, the result of calling the function is treated as an iterable, with each individual object being written to its corresponding output.",
            "x": 739.0371345687987,
            "y": 294.2178353185549,
            "repositoryUrl": "https://github.com/ICRAR/daliuge",
            "commitHash": "0c767dc",
            "paletteDownloadUrl": "https://raw.githubusercontent.com/ICRAR/EAGLE-graph-repo/master/daliuge/daliuge-master-template.palette",
            "dataHash": "83264c2930d04314860785d5395539788fbd510809b6fb49a6ad704f92481eb2",
            "parentId": "a3e88f46-f63d-4d04-995d-4aa3ef2fbd3f",
            "embedId": null,
            "fields": {
                "211c7ff5-8e2f-4e35-9a12-0b68f987fc1a": {
                    "name": "func_name",
                    "value": "extract_obsid",
                    "defaultValue": "",
                    "description": "Python function name",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "211c7ff5-8e2f-4e35-9a12-0b68f987fc1a",
                    "parameterType": "Component",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "85d1cb7d-7f90-4cc2-8479-960f2f8b7859": {
                    "name": "func_code",
                    "value": "def extract_obsid(InputList):\n  x=InputList[0].split(',')\n  for n in x:\n    if n[:6]=='obs_id':  # \"obs_id=1104585920, ....\n      obsid=n[7:]\n  return(obsid)",
                    "defaultValue": "t",
                    "description": "Python function code, e.g. 'def func_name(args): return args'. Note that func_name above needs to match the defined name here.",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "85d1cb7d-7f90-4cc2-8479-960f2f8b7859",
                    "parameterType": "Component",
                    "usage": "NoPort",
                    "edgeIds": []
                },
