                "74027856-2e04-4afe-a71a-7d7da116e7bf": {
                    "name": "gain",
                    "value": null,
                    "defaultValue": "0",
                    "description": "Cleaning gain: Ratio of peak that will be subtracted in each iteration",
                    "readonly": false,
                    "type": "Float",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "74027856-2e04-4afe-a71a-7d7da116e7bf",
                    "parameterType": "Application",
