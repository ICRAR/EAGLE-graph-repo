                },
                "e1cb46c8-caf4-4c5a-bbca-8eef448580f5": {
                    "name": "mgain",
                    "value": null,
                    "defaultValue": "0",
                    "description": "Cleaning gain for major iterations: Ratio of peak that will be subtracted in each major iteration. To use major iterations, 0.85 is a good value.",
                    "readonly": false,
                    "type": "Float",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "e1cb46c8-caf4-4c5a-bbca-8eef448580f5",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "74ef0f94-34ed-4e1d-89c3-204af554f5e8": {
                    "name": "join-polarizations",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Perform cleaning by searching for peaks in the sum of squares of the polarizations, but subtract components from the individual images. Only possible when imaging two or four Stokes or linear parameters",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "74ef0f94-34ed-4e1d-89c3-204af554f5e8",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "bb977af8-8085-40af-85ca-639b3f628460": {
                    "name": "join-channels",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Perform cleaning by searching for peaks in the MFS image, but subtract components from individual channels. This will turn on mfsweighting by default",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "bb977af8-8085-40af-85ca-639b3f628460",
