                "1f1d1979-57d6-4734-abd4-9fd36ea30120": {
                    "name": "dft-with-beam",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Apply the beam during DFT. Currently only works for LOFAR.",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
