                "74f12061-1348-4d97-a341-d512440a61d7": {
                    "name": "quite",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Do not output anything but errors.",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "74f12061-1348-4d97-a341-d512440a61d7",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "3c6f1d85-ba80-421a-af80-7b215c4a4403": {
                    "name": "reorder",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Force or disable reordering of Measurement Set. This can be faster when the measurement set needs to be iterated several times, such as with many major iterations or in channel imaging mode. If unspecified will only be enabled in channel imaging mode",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "3c6f1d85-ba80-421a-af80-7b215c4a4403",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "ff4ca276-7773-4d28-8222-c0db6d867405": {
                    "name": "no-update-model-required",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Save model data in model data column after imaging. It can save time not to update the model data column.",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "ff4ca276-7773-4d28-8222-c0db6d867405",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "879db4df-3fc0-47d6-8efc-da7770ca6e4f": {
                    "name": "no-dirty",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Do not save the dirty image",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "879db4df-3fc0-47d6-8efc-da7770ca6e4f",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "8f094f1f-25e6-42cc-8743-f7fb7009d3f0": {
                    "name": "saveweights",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Save the gridded weights in the a fits file named <image-prefix>-weights.fits.",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "8f094f1f-25e6-42cc-8743-f7fb7009d3f0",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "caed3725-d293-4054-8b34-6c6dd36cd9a7": {
                    "name": "apply-primary-beam",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Calculate and apply the primary beam and save images for the Jones components, with weighting identical to the weighting as used by the imager. Only available for LOFAR.",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "caed3725-d293-4054-8b34-6c6dd36cd9a7",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "ee09cc18-937b-4c34-9454-c77bab343dfa": {
                    "name": "reuse-primary-beam",
                    "value": false,
                    "defaultValue": "false",
                    "description": "If a primary beam image exists on disk, reuse those images (not implemented yet)",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "ee09cc18-937b-4c34-9454-c77bab343dfa",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "efbd177f-bb17-42e1-bbd2-e6681d9e08e7": {
                    "name": "save-uv",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Save the gridded uv plane, i.e., the FFT of the residual image. The UV plane is complex, hence two images will be output: <prefix>-uv-real.fits and <prefix>-uv-imag.fits",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "efbd177f-bb17-42e1-bbd2-e6681d9e08e7",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "e1013c40-a4aa-4638-8e6c-888f547420de": {
                    "name": "set-differential-lofar-beam",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Assume the visibilities have already been beam-corrected for the reference direction.",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "e1013c40-a4aa-4638-8e6c-888f547420de",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "c5d432ca-c827-4724-a263-27034efcee5b": {
                    "name": "weight",
                    "value": "",
                    "defaultValue": "",
                    "description": "Weightmode can be: natural, uniform, briggs. Default: uniform. When using Briggs' weighting, add the robustness parameter, like: 'weight briggs 0.5'",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "c5d432ca-c827-4724-a263-27034efcee5b",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "a9e7f4a8-cd92-4de9-9394-46d14499330d": {
                    "name": "super-weight",
                    "value": null,
                    "defaultValue": "0",
                    "description": "Increase the weight gridding box size, similar to Casa's superuniform weighting scheme. The factor can be rational and can be less than one for subpixel weighting.",
                    "readonly": false,
                    "type": "Float",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "a9e7f4a8-cd92-4de9-9394-46d14499330d",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "c3d3f67e-dd16-4326-b1ea-f4ffcc051a58": {
                    "name": "no-mfs-weighting",
                    "value": false,
                    "defaultValue": "false",
                    "description": "In spectral mode, calculate the weights as if the image was made using MFS. This makes sure that the sum of channel images equals the MFS weights. Otherwise, the channel image will become a bit more naturally weighted. This is only relevant for weighting modes that require gridding (i.e., Uniform, Briggs').",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "c3d3f67e-dd16-4326-b1ea-f4ffcc051a58",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "1372d84b-a3ed-45e0-8d77-f2bfaade155c": {
                    "name": "weighting-rank-filter",
                    "value": null,
                    "defaultValue": "0",
                    "description": "Filter the weights and set high weights to the local mean. The level parameter specifies the filter level; any value larger than level*localmean will be set to level*localmean.",
                    "readonly": false,
                    "type": "Float",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "1372d84b-a3ed-45e0-8d77-f2bfaade155c",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "db26d903-b8e9-4c59-a440-e48ffca91c5b": {
                    "name": "weighting-rank-filter-size",
                    "value": null,
                    "defaultValue": "0",
                    "description": "Set size of weighting rank filter",
                    "readonly": false,
                    "type": "Float",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "db26d903-b8e9-4c59-a440-e48ffca91c5b",
                    "parameterType": "Application",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "08b61c97-df60-4c34-b6c9-d7322a193d27": {
                    "name": "taper-gaussian",
                    "value": "",
                    "defaultValue": "",
                    "description": "Taper the weights with a Gaussian function. This will reduce the contribution of long baselines. The beamsize is by default in asec, but a unit can be specified as '2amin'",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
