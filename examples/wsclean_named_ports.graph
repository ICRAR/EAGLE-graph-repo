                "36e99474-a69c-4a5a-8dda-40d4304d213b": {
                    "name": "dft-prediction",
                    "value": false,
                    "defaultValue": "false",
                    "description": "Predict via a direct Fourier transform. This is slow, but can account for direction-dependent effects. This has only effect when 'mgain' is set or 'predict' is given.",
                    "readonly": false,
                    "type": "Boolean",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "36e99474-a69c-4a5a-8dda-40d4304d213b",
