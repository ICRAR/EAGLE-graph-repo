                "f642c804-067a-4d8b-a5bb-1ef1a1fdac8b": {
                    "name": "rms-background-method",
                    "value": "",
                    "defaultValue": "",
                    "description": "Either 'rms' (default, uses sliding window RMS) or 'rms-with-min' (use max(window rms,1.5/5window min))",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
