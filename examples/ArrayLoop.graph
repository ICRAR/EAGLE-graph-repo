{
    "modelData": {
        "filePath": "examples/ArrayLoop.graph",
        "fileType": "Graph",
        "shortDescription": "Graph using a scatter and a loop construct to distribute elements of of random array and write them to files.",
        "detailedDescription": "This graph generates a random array and splits that array using a scatter into smaller sub-arrays. Each of these scattered branches will then loop through the elements of  its respective sub-array and write a single element to a file. The number of scatter branches as well as the number of loops are user definable parameters, which also means that the total number of individual tasks is pre-defined. In turn that also means that unbounded loops like\n\n    while 1:\n       do_stuff\n\nor\n\n    for i in some_array:\n        do_stuff\n\nwhere the length of some_array is unknown, are not directly supported.",
        "repoService": "GitHub",
        "repoBranch": "master",
        "repo": "ICRAR/EAGLE-graph-repo",
        "generatorVersion": "v7.0.0",
        "generatorCommitHash": "1bc8245b685ff9cc257516d3d1768bb0c22d7806",
        "generatorName": "EAGLE",
        "schemaVersion": "OJS",
