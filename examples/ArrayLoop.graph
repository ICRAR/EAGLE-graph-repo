            "fields": [
                {
                    "name": "func_name",
                    "value": "find_log_files",
                    "defaultValue": "",
                    "description": "Python function name",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "c5bb4e8b-c1b3-4844-a554-d11d87d65517",
                    "parameterType": "ComponentParameter",
                    "usage": "NoPort"
                },
                {
                    "name": "func_code",
                    "value": "import glob\ndef find_log_files():\n\tfileList = glob.glob(\"*\")\n\tprint(f\"FileList: {fileList}\")\n\treturn fileList\n",
                    "defaultValue": "",
                    "description": "Python function code, e.g. 'def func_name(args): return args'. Note that func_name above needs to match the defined name here.",
