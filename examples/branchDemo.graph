{
    "modelData": {
        "name": "branchDemo.graph",
        "shortDescription": "Very simple branch demonstration using a random array and an in-line condition function.",
        "detailedDescription": "The condition function just checks for the mean of the random array and returns true or false depending on whether it is smaller than 0.5. The size and the range of the random array can be adjusted as well in the paramters of the RandomArrayApp. After completion a single file will be generated containing the mean value of the array.",
        "type": "Graph",
        "schemaVersion": "V4",
        "readonly": true,
