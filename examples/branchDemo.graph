        "16c83703-d5d6-4d1a-908d-dcbf53c5b2e3": {
            "category": "Branch",
            "categoryType": "Application",
            "id": "16c83703-d5d6-4d1a-908d-dcbf53c5b2e3",
            "name": "Branch",
            "description": "A branch application that copies the input to either the 'true' or the 'false' output depending on the result of the provided conditional function. The conditional function can be specified either in-line or as an external function and has to return a boolean value. The inputs of the application are passed on as arguments to the conditional function. The conditional function needs to return a boolean value, but the application will copy the input data to the true or false output, depending on the result of the conditional function.",
            "x": 756.9492053953827,
            "y": 410.2138370363139,
            "repositoryUrl": "https://github.com/ICRAR/daliuge",
            "commitHash": "8059e41",
            "paletteDownloadUrl": "https://raw.githubusercontent.com/ICRAR/EAGLE-graph-repo/master/daliuge/daliuge-master.palette",
            "dataHash": "fa8b3a7fe5ff225a150aad9fa0fba828816eaf71b73feb1cbf6295379a9464c2",
            "parentId": null,
            "embedId": null,
