                "fa20ce10-2026-411c-8a9d-cbc2b81c1653": {
                    "name": "func_code",
                    "value": "def generate_start_digits(precision: int = 10000, n_split: int = 10) -> range:\n    return list(range(0, precision, int(precision / n_split)))",
                    "defaultValue": "",
                    "description": "Python function code, e.g. 'def function_name(args): return args'",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
