                "e7fde152-3c06-4650-b95b-511458e1f1fa": {
                    "name": "func_code",
                    "value": "from decimal import getcontext\n\ndef decimal_sum(array, precision):\n    getcontext().prec = precision\n    dsum = sum(array)\n    return dsum",
