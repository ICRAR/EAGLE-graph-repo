            "name": "generate_start_digits",
            "description": "Generate the start\\_digits range based on the anticipated precision and number of split.",
            "x": 358.67279503197966,
            "y": 368.64232930308043,
            "repositoryUrl": "https://github.com/ICRAR/daliuge",
            "commitHash": "10110da",
