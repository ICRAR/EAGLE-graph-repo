                "da4f9acb-631a-4f89-9907-862a5f047752": {
                    "name": "func_code",
                    "value": "from decimal import Decimal, getcontext\n\ndef pi_k(start_digit: int = 0, n_digits: int = 16, precision: int = 32) -> Decimal:\n    if start_digit < 0 or n_digits < 1:\n        raise ValueError(\"Invalid value of start_digit or n_digits provided!\")\n\n    getcontext().prec = precision\n\n    pi_digits = sum(\n        1 / Decimal(16) ** k * (\n                Decimal(4) / (8 * k + 1) -\n                Decimal(2) / (8 * k + 4) -\n                Decimal(1) / (8 * k + 5) -\n                Decimal(1) / (8 * k + 6)\n        )\n        for k in range(start_digit, start_digit + n_digits)\n    )\n\n    return pi_digits",
                    "defaultValue": "",
                    "description": "",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "da4f9acb-631a-4f89-9907-862a5f047752",
                    "parameterType": "Component",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "6b3a058b-a2ca-4e8b-916d-09ce9abb9f6d": {
                    "name": "dropclass",
                    "value": "dlg.apps.pyfunc.PyFuncApp",
                    "defaultValue": "dlg.apps.pyfunc.PyFuncApp",
                    "description": "The python class that implements this application",
                    "readonly": true,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "6b3a058b-a2ca-4e8b-916d-09ce9abb9f6d",
                    "parameterType": "Component",
                    "usage": "NoPort",
                    "edgeIds": []
                }
            },
