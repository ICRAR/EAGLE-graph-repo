            "fields": {
                "569bdb48-ef8a-40df-9ad3-7c9983f720a9": {
                    "name": "func_name",
                    "value": "generate_start_digits",
                    "defaultValue": "",
                    "description": "Python function name",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
