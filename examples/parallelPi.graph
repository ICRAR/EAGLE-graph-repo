{
    "modelData": {
        "name": "parallelPi.graph",
        "shortDescription": "Parallel calculation of digits of PI",
        "detailedDescription": "An implementation of the generation of an arbitrary number of digits of PI. It is using a distributed version of the Bailey\u2013Borwein\u2013Plouffe formula. By using DALiuGE as a distribution mechanism, this allows a generation of PI across many compute nodes. The default setting generates 10,000 digits across 10 processes.",
        "type": "Graph",
        "schemaVersion": "V4",
        "readonly": true,
