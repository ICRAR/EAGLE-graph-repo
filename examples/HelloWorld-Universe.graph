{
    "modelData": {
        "name": "HelloWorld-Universe.graph",
        "shortDescription": "This graph demonstrates a distributed Hello World example using _Scatter_ and _Gather_ constructs.",
        "detailedDescription": "This graph demonstrates a distributed Hello World example. The input component on the left side _string2json_ defines 6 different strings which will be added to the string _Hello_ to form a greeting. These greetings are constructed in parallel inside the _Scatter_ construct. The resulting greetings are then gathered in a single file and written to disk. Note that all the intermediate data items are passed along in memory and only the final result is written to disk.",
        "type": "Graph",
        "schemaVersion": "V4",
        "readonly": true,
        "location": {
            "repositoryService": "GitHub",
            "repositoryBranch": "master",
