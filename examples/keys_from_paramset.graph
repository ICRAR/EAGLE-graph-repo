                "ca277551-c279-4773-a854-ec26de9f56c2": {
                    "name": "func_code",
                    "value": "def value_from_dict(dict_in: dict, dict_key: str):\n    \"\"\"\n    Select a value from a dictionary.\n\n    Parameters:\n    -----------\n    dict_in: input dictionary\n    dict_key: keyword to select\n\n    Returns:\n    --------\n    The value referred to by key.\n    \"\"\"\n    # We deliberatly let this fail if the type is not str or array like\n    dict_key = dict_key if isinstance(dict_key, str) else dict_key[0]\n    return dict_in[dict_key]",
                    "defaultValue": "",
                    "description": "Python function code, e.g. 'def func_name(args): return args'. Note that func_name above needs to match the defined name here.",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "ca277551-c279-4773-a854-ec26de9f56c2",
                    "parameterType": "Component",
                    "usage": "NoPort",
                    "edgeIds": []
                },
