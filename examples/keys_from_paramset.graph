        "a1b26e1a-6791-44e3-8a9f-c4ba0f923bed": {
            "category": "PyFuncApp",
            "categoryType": "Application",
            "id": "a1b26e1a-6791-44e3-8a9f-c4ba0f923bed",
            "name": "keys_from_dict",
            "description": "An application that wraps a simple python function. The inputs of the application are treated as the arguments of the function. Conversely, the output of the function is treated as the output of the application. If the application has more than one output, the result of calling the function is treated as an iterable, with each individual object being written to its corresponding output.",
            "x": 279.26854822001997,
            "y": 159.88599420887434,
            "repositoryUrl": "https://github.com/ICRAR/daliuge",
            "commitHash": "585ff99",
            "paletteDownloadUrl": "https://raw.githubusercontent.com/ICRAR/EAGLE_test_repo/master/daliuge/daliuge-master-template.palette",
            "dataHash": "deea3124ecb065724939d4702d8ae3b44cddcfc40e806c5cf5cf4d83c38e9580",
            "parentId": null,
            "embedId": null,
            "fields": {
                "647a553e-d091-4a11-a21f-be45cd2ab217": {
                    "name": "func_name",
                    "value": "keys_from_dict",
                    "defaultValue": "",
                    "description": "Python function name",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "647a553e-d091-4a11-a21f-be45cd2ab217",
                    "parameterType": "Component",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "d2a7c40a-e20c-4671-a8f5-0d5af1d84827": {
                    "name": "func_code",
                    "value": "def keys_from_dict(dict_in: dict) -> list:\n    \"\"\"\n    Return key list of dictionary.\n\n    Parameters:\n    -----------\n    dict_in: input dictionary\n\n    Returns:\n    --------\n    The list of keys\n    \"\"\"\n    return list(dict_in.keys())",
