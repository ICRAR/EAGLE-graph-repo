{
    "modelData": {
        "name": "FileCollector.graph",
        "shortDescription": "File retrieval  graph demonstrating how to use a branch construct to exit a loop.",
        "detailedDescription": "This graph is using glob to get a list of files matching a  wildcard string and then loops through them and copies the content to files in the session directory. The graph is demonstrating how to use a branch to exit a loop. In order to execute the graph the module [dlg-example-cmpts](https://github.com/ICRAR/daliuge-component-examples) has to be installed as instructed in the repository, or simply as a normal module.",
        "type": "Graph",
        "schemaVersion": "V4",
        "readonly": true,
