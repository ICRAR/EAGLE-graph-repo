        "7eaeeaa4-fb2e-461f-918f-50e0bdb41c59": {
            "category": "Branch",
            "categoryType": "Application",
            "id": "7eaeeaa4-fb2e-461f-918f-50e0bdb41c59",
            "name": "Branch",
            "description": "A branch application that copies the input to either the 'true' or the 'false' output depending on the result of the provided conditional function. The conditional function can be specified either in-line or as an external function and has to return a boolean value. The inputs of the application are passed on as arguments to the conditional function. The conditional function needs to return a boolean value, but the application will copy the input data to the true or false output, depending on the result of the conditional function.",
            "x": 1111.7040206791896,
            "y": 15.990866904821166,
            "repositoryUrl": "https://github.com/ICRAR/daliuge",
            "commitHash": "c83c0d9",
            "paletteDownloadUrl": "https://raw.githubusercontent.com/ICRAR/EAGLE-graph-repo/ba4118301a623cbe822d9466a6a71a8790b32b5c/daliuge/daliuge-liu-456.palette",
            "dataHash": "fa8b3a7fe5ff225a150aad9fa0fba828816eaf71b73feb1cbf6295379a9464c2",
            "parentId": "5a68172a-affa-47ad-b003-ea937cf8baa2",
            "embedId": null,
            "fields": {
                "47f020c6-2ec1-45a6-a712-7026344c0f05": {
                    "name": "func_name",
                    "value": "condition",
                    "defaultValue": "condition",
                    "description": "Python conditional function name. This can also be a valid import path to an importable function.",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "47f020c6-2ec1-45a6-a712-7026344c0f05",
                    "parameterType": "Component",
                    "usage": "NoPort",
                    "edgeIds": []
                },
                "18bbf329-bd47-4667-b697-65c455ef3ad3": {
                    "name": "func_code",
                    "value": "def condition(x):\n    return True if x and len(x) > 0 else False",
                    "defaultValue": "def condition(x): return (x > 0)",
                    "description": "Python function code for the branch condition. Modify as required. Note that func_name above needs to match the defined name here.",
                    "readonly": false,
                    "type": "String",
                    "precious": false,
                    "options": [],
                    "positional": false,
                    "encoding": "pickle",
                    "id": "18bbf329-bd47-4667-b697-65c455ef3ad3",
