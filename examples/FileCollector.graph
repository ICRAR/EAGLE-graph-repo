        "c8170969-a36f-43ff-913d-42d056f6364e": {
            "category": "PyFuncApp",
            "categoryType": "Application",
            "id": "c8170969-a36f-43ff-913d-42d056f6364e",
            "name": "fileGlob",
            "description": "An application that wraps a python function. The inputs of the application are treated as the arguments of the function. Conversely, the output of the function is treated as the output of the application. If the application has more than one output, the result of calling the function is treated as an iterable, with each individual object being written to its corresponding output.",
            "x": 734.9990052397585,
            "y": 61.115635881415294,
            "repositoryUrl": "https://github.com/ICRAR/daliuge",
            "commitHash": "9caf08d",
            "paletteDownloadUrl": "https://raw.githubusercontent.com/ICRAR/EAGLE-graph-repo/master/daliuge/daliuge-master-template.palette",
