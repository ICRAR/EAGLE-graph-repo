                "1fff45cd-e8c2-45cf-8b70-2b57692996ff": {
                    "name": "func_code",
                    "value": "from glob import glob\ndef fileGlob(wildcard):\n    flist =   glob(wildcard)\n    print(f\"Files found: {flist}\")\n    return flist",
