    "modelData": {
        "name": "memory_with_data.graph",
        "shortDescription": "Graph defining data for a memory drop",
        "detailedDescription": "Example graph showing how to define simple data values directly for a MemoryDROP. Supported types are:\n\n- string\n- int\n- float\n- boolean\n- json\n- object\n\nIf object is used the provided value needs to be a base64 encoded pickle binary string obtained by:\nbase64.b64encode(pickle.dumps(<your object>))",
        "type": "Graph",
        "schemaVersion": "V4",
        "readonly": true,
