                "e8791ad2-0cb3-4fea-b57c-f73e0d9f2cd7": {
                    "name": "func_code",
                    "value": "import time\ndef inv_sleep(sleep_time):\n  sleep_time = 5 - sleep_time\n  time.sleep(sleep_time)\n  print(f\"Slept {sleep_time:.2f}s\")\n  return sleep_time",
                    "defaultValue": "import time\ndef inv_sleep(sleep_time):\n  time.sleep(1-sleep_time)\n  return 1-sleep_time",
                    "description": "Python function code, e.g. 'def func_name(args): return args'. Note that func_name above needs to match the defined name here.",
